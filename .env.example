# ---- Required ----------------------------------------------------------
# HuggingFace token: needed for vLLM to download the base model + LoRAs.
HF_TOKEN=hf_xxx

# ---- Server / UI wiring (defaults are usually fine for docker compose) -
# Where adaptive_minds.server hits vLLM (inside the compose network).
VLLM_BASE=http://vllm:8000/v1

# Where the Next.js UI fetches the FastAPI server from the BROWSER (so
# this must be a host-reachable URL — not the compose-internal hostname).
# Baked in at `docker compose build` time; default tracks AM_SERVER_PORT.
# Set this if the server is behind a reverse proxy or remapped to a
# different host.
# NEXT_PUBLIC_AM_API_BASE=http://localhost:8765

# Default mode the UI boots in: "router" or "agent".
# NEXT_PUBLIC_DEFAULT_MODE=router

# Catalog the FastAPI server loads at startup. Change this to
# /app/catalogs/qwen25_30.yaml (and update vllm.command in
# docker-compose.yml to match) once you've smoke-tested the 2-adapter
# config.
AM_CATALOG=/app/catalogs/qwen25_smoke.yaml

# ---- Host-port overrides (uncomment if 8000/8765/3000 are taken) -------
# AM_VLLM_PORT=8001
# AM_SERVER_PORT=8766
# AM_UI_PORT=3001
