# ---- Required ----------------------------------------------------------
# HuggingFace token: needed for vLLM to download the base model + LoRAs.
HF_TOKEN=hf_xxx

# ---- Server / UI wiring (defaults are usually fine for docker compose) -
# Where adaptive_minds.server hits vLLM (inside the compose network).
VLLM_BASE=http://vllm:8000/v1

# The Next.js UI proxies browser → API via its own server (`/api/am/* →
# server:8765`), so the bundle uses relative URLs and the same image
# works from localhost, a public IP, or behind a reverse proxy. Override
# only if you've split the UI off and want it to hit FastAPI directly:
# NEXT_PUBLIC_AM_API_BASE=https://api.example.com

# Default mode the UI boots in: router | agent | auto | langgraph.
# NEXT_PUBLIC_DEFAULT_MODE=router

# Catalog the FastAPI server loads at startup. Defaults to the paper's
# 30-adapter catalog. Swap to qwen25_smoke.yaml for a 2-adapter fast boot.
AM_CATALOG=/app/catalogs/qwen25_30.yaml

# ---- Host-port overrides (uncomment if 8000/8765/7007 are taken) -------
# AM_VLLM_PORT=8001
# AM_SERVER_PORT=8766
# AM_UI_PORT=7008
