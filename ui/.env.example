# Where the browser fetches the FastAPI server. The server has CORS open
# (allow_origins=["*"]) so the browser hits it directly — no Next.js
# server-side proxy needed.
#
# In docker compose this resolves at build time to the host port mapping
# (default http://localhost:8765). Outside compose, set it to wherever your
# adaptive-minds server is listening.
NEXT_PUBLIC_AM_API_BASE=http://localhost:8765

# Default mode in the UI: "router" (one LLM call → adapter) or "agent"
# (ReAct loop with tools + experts).
NEXT_PUBLIC_DEFAULT_MODE=router
